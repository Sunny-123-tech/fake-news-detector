# =============================================================
#  Fake News Detector — Backend Environment Variables
# =============================================================

# ── DATABASE ─────────────────────────────────────────────────
# Format for db4free.net:
# mysql+pymysql://<username>:<password>@db4free.net:3306/<dbname>
#
# Replace the values below AFTER you register on db4free.net
DATABASE_URL=mysql+pymysql://YOUR_DB4FREE_USERNAME:YOUR_DB4FREE_PASSWORD@db4free.net:3306/YOUR_DB4FREE_DBNAME

# ── GROQ AI ──────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── JWT SECRET ───────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
